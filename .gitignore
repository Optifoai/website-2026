
# Learn more about .gitignore:
#     https://www.atlassian.com/git/tutorials/saving-changes/gitignore

# Dependency directories
node_modules/
.cursor/

# Build output
dist/
dist-ssr/
target/
build/

# Logs & Debug files
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Environment variables - DO NOT COMMIT SENSITIVE DATA
.env
.env.*
!.env.example
*.local

# IDE & Editor directories
.vscode/*
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# OS-generated files
.DS_Store
Thumbs.db

# Compiled files & Packages
*.class
*.py[cod]
*.jar
*.war
*.app
*.exe

# Unit test reports
TEST*.xml

# Large media files (consider Git LFS instead)
*.mp4
*.tiff
*.avi
*.flv
*.mov
*.wmv
